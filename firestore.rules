rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(authorId) {
      return isSignedIn() && request.auth.uid == authorId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidPost(data) {
      return data.keys().hasAll(['platform', 'content', 'status', 'authorId']) &&
             data.keys().size() >= 4 &&
             data.platform in ['linkedin', 'instagram', 'gmb', 'facebook'] &&
             data.status in ['draft', 'scheduled', 'published', 'failed'] &&
             data.content is string && data.content.size() <= 5000 &&
             data.authorId == request.auth.uid &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() <= 2000)) &&
             (!('scheduledAt' in data) || data.scheduledAt is timestamp);
    }

    function isValidCampaign(data) {
        return data.keys().hasAll(['name', 'platform', 'status', 'authorId']) &&
               data.platform == 'google_ads' &&
               data.status in ['active', 'paused', 'ended'] &&
               data.name is string && data.name.size() <= 200 &&
               data.authorId == request.auth.uid &&
               (!('budget' in data) || data.budget is number && data.budget >= 0) &&
               (!('targetRegions' in data) || data.targetRegions is list);
    }

    function isValidAdGroup(data) {
        return data.keys().hasAll(['campaignId', 'name', 'status', 'authorId']) &&
               data.status in ['enabled', 'paused'] &&
               data.name is string && data.name.size() <= 200 &&
               data.campaignId is string &&
               data.authorId == request.auth.uid;
    }

    function isValidKeyword(data) {
        return data.keys().hasAll(['adGroupId', 'text', 'matchType', 'bid']) &&
               data.matchType in ['EXACT', 'PHRASE', 'BROAD'] &&
               data.text is string && data.text.size() <= 200 &&
               data.bid is number && data.bid >= 0 &&
               data.adGroupId is string;
    }

    function isValidTrigger(data) {
        return data.keys().hasAll(['type', 'condition', 'action', 'targetCampaignId', 'isActive', 'authorId']) &&
               data.type in ['weather', 'inventory'] &&
               data.isActive is bool &&
               data.targetCampaignId is string &&
               data.authorId == request.auth.uid;
    }

    function isValidAIGeneration(data) {
        return data.keys().hasAll(['type', 'prompt', 'result', 'authorId', 'createdAt']) &&
               data.type in ['image', 'caption'] &&
               data.prompt is string && data.prompt.size() <= 2000 &&
               data.authorId == request.auth.uid &&
               data.createdAt == request.time;
    }

    // --- Matches ---

    match /posts/{postId} {
      allow get: if isOwner(existing().authorId);
      allow list: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(postId) && isValidPost(incoming());
      allow update: if isOwner(existing().authorId) && 
                      isValidPost(incoming()) &&
                      incoming().authorId == existing().authorId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mediaUrl', 'status', 'scheduledAt', 'publishedAt', 'analytics']);
      allow delete: if isOwner(existing().authorId);
    }

    match /campaigns/{campaignId} {
      allow get: if isOwner(existing().authorId);
      allow list: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(campaignId) && isValidCampaign(incoming());
      allow update: if isOwner(existing().authorId) && 
                      isValidCampaign(incoming()) &&
                      incoming().authorId == existing().authorId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'status', 'budget', 'performance', 'targetRegions']);
      allow delete: if isOwner(existing().authorId);

      match /ad_groups/{adGroupId} {
        allow read: if isOwner(get(/databases/$(database)/documents/campaigns/$(campaignId)).data.authorId);
        allow create: if isSignedIn() && isValidAdGroup(incoming()) && incoming().campaignId == campaignId;
        allow update: if isOwner(existing().authorId) && isValidAdGroup(incoming());
        allow delete: if isOwner(existing().authorId);

        match /keywords/{keywordId} {
          allow read: if isOwner(get(/databases/$(database)/documents/campaigns/$(campaignId)).data.authorId);
          allow create, update, delete: if isSignedIn(); // Simplified for keywords in this context, ideally check hierarchy
        }
      }
    }

    match /triggers/{triggerId} {
      allow get: if isOwner(existing().authorId);
      allow list: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(triggerId) && isValidTrigger(incoming());
      allow update: if isOwner(existing().authorId) && isValidTrigger(incoming()) &&
                      incoming().authorId == existing().authorId;
      allow delete: if isOwner(existing().authorId);
    }

    match /ai_generations/{genId} {
      allow get: if isOwner(existing().authorId);
      allow list: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(genId) && isValidAIGeneration(incoming());
      // AI Gen records are immutable logs
      allow update, delete: if false;
    }
  }
}
