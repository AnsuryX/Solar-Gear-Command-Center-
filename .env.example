# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# REPLICATE_API_TOKEN: Required for AI image generation (Flux).
REPLICATE_API_TOKEN="MY_REPLICATE_TOKEN"

# Social Media API Keys (Direct Integration)
# LinkedIn
LINKEDIN_CLIENT_ID="MY_LINKEDIN_CLIENT_ID"
LINKEDIN_CLIENT_SECRET="MY_LINKEDIN_CLIENT_SECRET"

# Meta (Instagram/Facebook)
META_APP_ID="MY_META_APP_ID"
META_APP_SECRET="MY_META_APP_SECRET"

# AI Connectors
OPENROUTER_API_KEY="MY_OPENROUTER_KEY"
# Prefer openrouter model IDs like 'google/gemini-2.0-flash-lite-001'
VITE_AI_MODEL_ID="google/gemini-2.0-flash-lite-001"

# External Automation
NEXUS_API_SECRET="your-secure-nexus-bridge-key"
VITE_AI_PROVIDER="gemini" # or "openrouter"

# Google Ads (Direct Integration)
GOOGLE_ADS_CLIENT_ID="MY_GOOGLE_ADS_CLIENT_ID"
GOOGLE_ADS_CLIENT_SECRET="MY_GOOGLE_ADS_CLIENT_SECRET"
GOOGLE_ADS_DEVELOPER_TOKEN="MY_DEV_TOKEN"
GOOGLE_ADS_REFRESH_TOKEN="MY_REFRESH_TOKEN"
GOOGLE_ADS_CUSTOMER_ID="MY_CUSTOMER_ID"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
