{
  "entities": {
    "Post": {
      "title": "Marketing Post",
      "description": "Represents a social media post for various platforms.",
      "type": "object",
      "properties": {
        "platform": {
          "type": "string",
          "enum": ["linkedin", "instagram", "gmb", "facebook"],
          "description": "Target social media platform."
        },
        "content": {
          "type": "string",
          "description": "The text content of the post."
        },
        "mediaUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL to the image or video asset."
        },
        "status": {
          "type": "string",
          "enum": ["draft", "pending_approval", "approved", "scheduled", "published", "failed"],
          "description": "Current status of the post."
        },
        "scheduledAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the post should be published."
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the post was actually published."
        },
        "ayrshareId": {
          "type": "string",
          "description": "ID returned by Ayrshare after scheduling/posting."
        },
        "authorId": {
          "type": "string",
          "description": "The UID of the user who created this post."
        },
        "analytics": {
          "type": "object",
          "properties": {
            "impressions": { "type": "integer" },
            "clicks": { "type": "integer" },
            "engagement": { "type": "number" }
          }
        }
      },
      "required": ["platform", "content", "status", "authorId"]
    },
    "WeeklyStrategy": {
      "title": "Weekly Content Strategy",
      "description": "A week-long content plan generated by AI.",
      "type": "object",
      "properties": {
        "weekStartDate": { "type": "string", "format": "date" },
        "strategyDescription": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["weekStartDate", "authorId"]
    },
    "Campaign": {
      "title": "Marketing Campaign",
      "description": "Represents a paid advertising campaign (e.g., Google Ads).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "platform": { "type": "string", "enum": ["google_ads"] },
        "status": { "type": "string", "enum": ["active", "paused", "ended"] },
        "budget": { "type": "number" },
        "targetRegions": { "type": "array", "items": { "type": "string" } },
        "performance": {
          "type": "object",
          "properties": {
            "spend": { "type": "number" },
            "clicks": { "type": "integer" },
            "conversions": { "type": "integer" }
          }
        },
        "authorId": { "type": "string" }
      },
      "required": ["name", "platform", "status", "authorId"]
    },
    "AdGroup": {
      "title": "Ad Group",
      "description": "A group of ads within a campaign.",
      "type": "object",
      "properties": {
        "campaignId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["enabled", "paused"] },
        "authorId": { "type": "string" }
      },
      "required": ["campaignId", "name", "status", "authorId"]
    },
    "Keyword": {
      "title": "Keyword",
      "description": "Target keywords for search ads.",
      "type": "object",
      "properties": {
        "adGroupId": { "type": "string" },
        "text": { "type": "string" },
        "matchType": { "type": "string", "enum": ["EXACT", "PHRASE", "BROAD"] },
        "bid": { "type": "number" },
        "status": { "type": "string", "enum": ["enabled", "paused"] }
      },
      "required": ["adGroupId", "text", "matchType", "bid"]
    },
    "AutomationTrigger": {
      "title": "Automation Trigger",
      "description": "Rules for automated ad adjustments.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["weather", "inventory"] },
        "condition": { "type": "string" },
        "action": { "type": "string" },
        "targetCampaignId": { "type": "string" },
        "adjustment": { "type": "number" },
        "isActive": { "type": "boolean" },
        "authorId": { "type": "string" }
      },
      "required": ["type", "condition", "action", "targetCampaignId", "isActive", "authorId"]
    },
    "AIGeneration": {
      "title": "AI Content Generation",
      "description": "Records of AI-generated assets (images, text).",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["image", "caption"] },
        "prompt": { "type": "string" },
        "result": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "prompt", "result", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of social media posts."
    },
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Collection of marketing campaigns."
    },
    "/campaigns/{campaignId}/ad_groups/{adGroupId}": {
      "schema": "AdGroup",
      "description": "Ad groups within a campaign."
    },
    "/campaigns/{campaignId}/ad_groups/{adGroupId}/keywords/{keywordId}": {
      "schema": "Keyword",
      "description": "Keywords for an ad group."
    },
    "/triggers/{triggerId}": {
      "schema": "AutomationTrigger",
      "description": "Rules for automated ad adjustments."
    },
    "/ai_generations/{genId}": {
      "schema": "AIGeneration",
      "description": "Log of AI generations."
    },
    "/weekly_strategies/{stratId}": {
      "schema": "WeeklyStrategy",
      "description": "Collection of AI-generated content calendars."
    }
  }
}
